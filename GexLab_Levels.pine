// GexLab Levels Indicator
// Paste the bridge payload from GexLab into the "Bridge Payload" input.
// Enter the aggregated levels from the Overview page manually.
// Re-paste the payload any time the market map updates.
// (The GexLab TradingView Auto-Sync userscript fills all of these for you.)
//@version=5
indicator("GexLab Levels", overlay=true, max_lines_count=100, max_labels_count=100)

// ─── Bridge Payload ────────────────────────────────────────────────────────
// Paste the output of "Copy Bridge" from GexLab Studio here. Carries per-DTE
// walls + gamma flip for 0/1/7/14/30/45 DTE.
bridge = input.string(
     '{"d0cw":null,"d0pw":null,"d0vt":null,"d1cw":null,"d1pw":null,"d1vt":null}',
     title="Bridge Payload",
     tooltip="Click Copy Bridge in GexLab then paste the result here.")

// ─── Aggregated Level Inputs (read from GexLab Overview) ──────────────────
grp_agg = "Aggregated Levels (from Overview)"
show_agg   = input.bool(true,  "Show Aggregated Levels", group=grp_agg)
agg_gflip  = input.float(0.0,  "Gamma Flip",  group=grp_agg)
agg_cwall  = input.float(0.0,  "Call Wall",   group=grp_agg)
agg_pwall  = input.float(0.0,  "Put Wall",    group=grp_agg)
agg_maxpain= input.float(0.0,  "Max Pain",    group=grp_agg)
agg_vanna  = input.float(0.0,  "Vanna Peak",  group=grp_agg)

// ─── DTE Display Toggles ──────────────────────────────────────────────────
grp_dte = "DTE Packs (from Bridge Payload)"
show_0dte  = input.bool(true,  "Show 0DTE Levels",  group=grp_dte)
show_1dte  = input.bool(true,  "Show 1DTE Levels",  group=grp_dte)
show_7dte  = input.bool(false, "Show 7DTE Levels",  group=grp_dte)
show_14dte = input.bool(false, "Show 14DTE Levels", group=grp_dte)
show_30dte = input.bool(false, "Show 30DTE Levels", group=grp_dte)
show_45dte = input.bool(false, "Show 45DTE Levels", group=grp_dte)

// ─── JSON Parser ──────────────────────────────────────────────────────────
// Extracts a numeric value from a compact JSON string by key name.
parse_field(json, key) =>
    search = '"' + key + '":'
    idx = str.pos(json, search)
    result = float(na)
    if not na(idx)
        start = idx + str.length(search)
        rest = str.substring(json, start)
        end_comma = str.pos(rest, ",")
        end_brace = str.pos(rest, "}")
        end_pos = na(end_comma) ? end_brace : na(end_brace) ? end_comma : math.min(end_comma, end_brace)
        if not na(end_pos)
            val_str = str.substring(rest, 0, end_pos)
            if val_str != "null"
                result := str.tonumber(val_str)
    result

// ─── Draw Helpers ─────────────────────────────────────────────────────────
make_line(price, col, ls) =>
    line.new(bar_index - 100, price, bar_index, price,
         color=col, width=1, style=ls, extend=extend.right)

make_label(price, txt, col) =>
    label.new(bar_index + 2, price, txt,
         color=color.new(col, 85), textcolor=col,
         style=label.style_label_left, size=size.small)

// ─── Aggregated Line State ────────────────────────────────────────────────
var line l_gflip   = na
var line l_cwall   = na
var line l_pwall   = na
var line l_maxpain = na
var line l_vanna   = na

var label lb_gflip   = na
var label lb_cwall   = na
var label lb_pwall   = na
var label lb_maxpain = na
var label lb_vanna   = na

// ─── DTE Line/Label Pools ─────────────────────────────────────────────────
// The per-DTE packs are drawn into arrays so adding DTE tiers needs no new
// per-level state. Everything is cleared and redrawn on the last bar.
var line[]  dte_lines  = array.new_line()
var label[] dte_labels = array.new_label()

// Draw one DTE pack (call wall / put wall / gamma flip) with a base
// transparency that fades the further-dated tiers into the background.
draw_dte_pack(show, label_tag, cw, pw, vt, transp, ls) =>
    if show
        line_t  = transp
        label_t = math.max(transp - 20, 20)
        if not na(cw) and cw > 0
            array.push(dte_lines,  make_line(cw, color.new(color.teal, line_t), ls))
            array.push(dte_labels, make_label(cw, label_tag + " CW "   + str.tostring(cw, "#.00"), color.new(color.teal, label_t)))
        if not na(pw) and pw > 0
            array.push(dte_lines,  make_line(pw, color.new(color.red, line_t), ls))
            array.push(dte_labels, make_label(pw, label_tag + " PW "   + str.tostring(pw, "#.00"), color.new(color.red, label_t)))
        if not na(vt) and vt > 0
            array.push(dte_lines,  make_line(vt, color.new(color.yellow, line_t), ls))
            array.push(dte_labels, make_label(vt, label_tag + " Flip " + str.tostring(vt, "#.00"), color.new(color.yellow, label_t)))

// ─── Redraw on Last Bar ───────────────────────────────────────────────────
if barstate.islast

    // — Aggregated levels —
    line.delete(l_gflip),   label.delete(lb_gflip)
    line.delete(l_cwall),   label.delete(lb_cwall)
    line.delete(l_pwall),   label.delete(lb_pwall)
    line.delete(l_maxpain), label.delete(lb_maxpain)
    line.delete(l_vanna),   label.delete(lb_vanna)

    if show_agg
        if agg_gflip > 0
            l_gflip   := make_line(agg_gflip,   color.yellow,        line.style_solid)
            lb_gflip  := make_label(agg_gflip,  "GEX Flip " + str.tostring(agg_gflip, "#.00"),  color.yellow)
        if agg_cwall > 0
            l_cwall   := make_line(agg_cwall,   color.teal,          line.style_solid)
            lb_cwall  := make_label(agg_cwall,  "Call Wall " + str.tostring(agg_cwall, "#.00"), color.teal)
        if agg_pwall > 0
            l_pwall   := make_line(agg_pwall,   color.red,           line.style_solid)
            lb_pwall  := make_label(agg_pwall,  "Put Wall " + str.tostring(agg_pwall, "#.00"),  color.red)
        if agg_maxpain > 0
            l_maxpain := make_line(agg_maxpain, color.orange,        line.style_dashed)
            lb_maxpain:= make_label(agg_maxpain,"Max Pain " + str.tostring(agg_maxpain, "#.00"),color.orange)
        if agg_vanna > 0
            l_vanna   := make_line(agg_vanna,   color.purple,        line.style_dotted)
            lb_vanna  := make_label(agg_vanna,  "Vanna Peak " + str.tostring(agg_vanna, "#.00"),color.purple)

    // — Per-DTE packs — clear the pools then redraw each enabled tier —
    if array.size(dte_lines) > 0
        for i = 0 to array.size(dte_lines) - 1
            line.delete(array.get(dte_lines, i))
        array.clear(dte_lines)
    if array.size(dte_labels) > 0
        for i = 0 to array.size(dte_labels) - 1
            label.delete(array.get(dte_labels, i))
        array.clear(dte_labels)

    // Nearer expiries drawn boldest (lower transparency), further ones fade out.
    draw_dte_pack(show_0dte,  "0DTE",  parse_field(bridge, "d0cw"),  parse_field(bridge, "d0pw"),  parse_field(bridge, "d0vt"),  50, line.style_dashed)
    draw_dte_pack(show_1dte,  "1DTE",  parse_field(bridge, "d1cw"),  parse_field(bridge, "d1pw"),  parse_field(bridge, "d1vt"),  60, line.style_dotted)
    draw_dte_pack(show_7dte,  "7DTE",  parse_field(bridge, "d7cw"),  parse_field(bridge, "d7pw"),  parse_field(bridge, "d7vt"),  70, line.style_dotted)
    draw_dte_pack(show_14dte, "14DTE", parse_field(bridge, "d14cw"), parse_field(bridge, "d14pw"), parse_field(bridge, "d14vt"), 75, line.style_dotted)
    draw_dte_pack(show_30dte, "30DTE", parse_field(bridge, "d30cw"), parse_field(bridge, "d30pw"), parse_field(bridge, "d30vt"), 80, line.style_dotted)
    draw_dte_pack(show_45dte, "45DTE", parse_field(bridge, "d45cw"), parse_field(bridge, "d45pw"), parse_field(bridge, "d45vt"), 82, line.style_dotted)
